{
    "version": "2.0.0",
    "configurations": [
        //Run editor
        {
            "name": "Editor",
            "type": "coreclr",
            "request": "launch",
            "program": "${config:cur.godotPath}",
            "args": [ "--editor", "--path", "${workspaceFolder}" ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "preLaunchTask": "build"
        },

        //Release mode
        {
            "name": "Launch Project",
            "type": "coreclr",
            "request": "launch",
            "program": "${config:cur.godotPath}",
            "args": [ "--path", "${workspaceFolder}" ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "preLaunchTask": "build"
        },

        //Debug mode
        {
            "name": "Launch Project (Debug)",
            "type": "coreclr",
            "request": "launch",
            "program": "${config:cur.godotPath}",
            "args": [ "--path", "${workspaceFolder}", "--debug" ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "preLaunchTask": "build"
        },
    ]
}